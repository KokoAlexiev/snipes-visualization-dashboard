# Copy to .env for local `netlify dev` (Netlify UI → Environment variables for production)

# --- Required ---
DISCORD_BOT_TOKEN=

# --- Supabase cache (strongly recommended) ---
# URL: Supabase project Settings → API → Project URL
SUPABASE_URL=
# Service role key: Supabase project Settings → API → service_role (secret)
# The Netlify function uses this server-side; NEVER expose it in public/ or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Optional Discord channel / guild overrides ---
# Defaults match the original generate_snipes_chart script. Only set if you use different channels.
# DISCORD_GUILD_ID=
# DISCORD_CREATE_TRADES_CHANNEL_ID=
# DISCORD_TRADE_SUCCESS_CHANNEL_ID=
